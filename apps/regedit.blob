{
  "title": "Registry Editor",
  "width": 600,
  "height": 450,
  "html": "<div class='reg-container'><div class='reg-sidebar'></div><div class='reg-main'>Select a key to view or modify.</div></div>",
  "css": ".reg-container { display: flex; height: 100%; background: white; } .reg-sidebar { width: 200px; border-right: 1px solid #ccc; overflow: auto; padding: 5px; font-size: 11px; } .reg-main { flex-grow: 1; overflow: auto; padding: 10px; font-size: 11px; } .reg-item { cursor: pointer; padding: 2px 5px; } .reg-item:hover { background: #316ac5; color: white; }",
  "js": "var sidebar = container.querySelector('.reg-sidebar'); var main = container.querySelector('.reg-main'); function render(obj, path, parent) { for (var key in obj) { (function(k, v) { var p = path + '/' + k; var isObj = typeof v === 'object' && v !== null && !Array.isArray(v); var item = document.createElement('div'); item.className = 'reg-item'; item.innerText = (isObj ? '[+] ' : '') + k; item.onclick = function(e) { e.stopPropagation(); main.innerHTML = '<strong>' + p + '</strong><hr>'; if (isObj) { for (var sk in v) { var row = document.createElement('div'); row.innerText = sk + ' : ' + JSON.stringify(v[sk]); main.appendChild(row); } } else { main.innerHTML += 'Value: ' + JSON.stringify(v); var btn = document.createElement('button'); btn.innerText = 'Modify'; btn.onclick = function() { XP_API.UAC.requestEscalation(function(s) { if (s) { XP_API.showDialog({ type: 'prompt', title: 'Edit', message: 'Value:', onOk: function(nv) { XP_API.Registry.set(p, nv); refresh(); } }); } }); }; main.appendChild(btn); } }; parent.appendChild(item); if (isObj) { var sub = document.createElement('div'); sub.style.paddingLeft = '15px'; sub.style.display = 'none'; parent.appendChild(sub); item.ondblclick = function() { sub.style.display = sub.style.display === 'none' ? 'block' : 'none'; }; render(v, p, sub); } })(key, obj[key]); } } function refresh() { sidebar.innerHTML = '<strong>My Computer</strong>'; render(XP_API.Registry.getAll(), '', sidebar); } refresh();"
}
