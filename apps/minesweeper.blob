{
  "title": "Minesweeper",
  "width": 200,
  "height": 250,
  "html": "<div class='ms-grid'></div>",
  "css": ".ms-grid { display: grid; grid-template-columns: repeat(8, 20px); gap: 1px; background: #808080; padding: 10px; } .ms-cell { width: 20px; height: 20px; background: #c0c0c0; border: 2px outset #fff; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold; cursor: pointer; } .ms-cell.revealed { border: 1px solid #808080; background: #c0c0c0; }",
  "js": "var grid = container.querySelector('.ms-grid'); var size = 8; var mines = 10; var cells = []; for (var i=0; i<size*size; i++) { var c = document.createElement('div'); c.className = 'ms-cell'; (function(idx) { c.onclick = function() { c.className = 'ms-cell revealed'; if (Math.random() < 0.2) { c.innerText = '💣'; XP_API.showDialog({ message: 'Game Over!' }); } else { c.innerText = Math.floor(Math.random()*3); } }; })(i); grid.appendChild(c); }"
}
