{
  "title": "Notepad",
  "width": 500,
  "height": 400,
  "html": "<div class='notepad-container'><div class='notepad-menu'></div><textarea class='notepad-textarea'></textarea></div>",
  "css": ".notepad-container { display: flex; flex-direction: column; height: 100%; } .notepad-menu { padding: 2px 5px; background: #ece9d8; border-bottom: 1px solid #aca899; } .notepad-textarea { flex-grow: 1; border: none; outline: none; resize: none; font-family: monospace; padding: 5px; } .notepad-menu button { margin-right: 5px; padding: 2px 10px; font-size: 11px; }",
  "js": "var filePath = args.filePath || ''; var content = filePath ? VFS.readFile(filePath) : ''; if (filePath && content === null) return; var menu = container.querySelector('.notepad-menu'); var textarea = container.querySelector('.notepad-textarea'); textarea.value = content; var saveBtn = document.createElement('button'); saveBtn.innerText = 'Save'; saveBtn.onclick = function() { if (!filePath) { XP_API.showDialog({ type: 'prompt', title: 'Save As', message: 'Enter file name:', onOk: function(name) { if (name) { filePath = 'C:/Documents/' + name; if (VFS.writeFile(filePath, textarea.value)) { if (window.renderDesktop) window.renderDesktop(); XP_API.showDialog({ message: 'File saved to ' + filePath }); XP_API.setWindowTitle(winId, filePath + ' - Notepad'); } } } }); } else { if (VFS.writeFile(filePath, textarea.value)) { if (window.renderDesktop) window.renderDesktop(); XP_API.showDialog({ message: 'File saved.' }); } } }; menu.appendChild(saveBtn); var wordWrap = XP_API.Registry.get('Apps/Notepad/WordWrap'); textarea.style.whiteSpace = wordWrap ? 'pre-wrap' : 'pre'; textarea.style.overflowX = wordWrap ? 'hidden' : 'auto'; XP_API.setWindowTitle(winId, (filePath || 'Untitled') + ' - Notepad');"
}
