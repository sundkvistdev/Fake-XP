{
  "title": "Display Properties",
  "width": 400,
  "height": 450,
  "html": "<div class='dp-tabs'><div class='dp-tab active'>Desktop</div></div><div class='dp-content'><div class='dp-preview'></div><div class='dp-settings'><span>Background:</span><select id='dp-bg-select'></select></div></div><div class='dp-footer'><button id='dp-ok'>OK</button><button id='dp-cancel'>Cancel</button></div>",
  "css": ".dp-tabs { display: flex; background: #ece9d8; padding: 5px 5px 0 5px; border-bottom: 1px solid #aca899; } .dp-tab { padding: 5px 15px; border: 1px solid #aca899; border-bottom: none; background: #f0f0f0; cursor: pointer; font-size: 11px; } .dp-tab.active { background: white; margin-bottom: -1px; position: relative; z-index: 1; } .dp-content { padding: 20px; background: white; flex-grow: 1; border: 1px solid #aca899; border-top: none; } .dp-preview { width: 200px; height: 120px; background: #004e98; border: 5px solid #333; margin: 0 auto 20px auto; background-size: cover; } .dp-footer { padding: 10px; display: flex; justify-content: flex-end; gap: 10px; background: #ece9d8; }",
  "js": "var sct = XP_API.Registry.get('System'); var preview = container.querySelector('.dp-preview'); var select = container.querySelector('#dp-bg-select'); var wallpapers = ['Bliss', 'Autumn', 'Azul', 'Vantage']; wallpapers.forEach(function(w) { var opt = document.createElement('option'); opt.value = 'https://picsum.photos/seed/' + w + '/1920/1080'; opt.innerText = w; select.appendChild(opt); }); preview.style.backgroundImage = 'url(' + sct.Wallpaper + ')'; select.onchange = function() { preview.style.backgroundImage = 'url(' + select.value + ')'; }; container.querySelector('#dp-ok').onclick = function() { sct.Wallpaper = select.value; XP_API.Registry.set('System', sct); document.getElementById('desktop').style.backgroundImage = 'url(' + sct.Wallpaper + ')'; XP_API.closeWindow(winId); }; container.querySelector('#dp-cancel').onclick = function() { XP_API.closeWindow(winId); };"
}
