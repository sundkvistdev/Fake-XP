{
  "title": "CentralFirm Antivirus",
  "width": 550,
  "height": 500,
  "html": "<div class='av-header'>🛡️ CentralFirm Antivirus</div><div class='av-main'><div class='av-status'>System Status: <span id='av-status-text'>Protected</span></div><div class='av-progress-container' style='display:none;'><div id='av-progress-bar'></div></div><div class='av-results'></div><button class='xp-button' id='scan-btn'>Scan Now</button></div>",
  "css": ".av-header { background: linear-gradient(to right, #003366, #006699); padding: 15px; color: white; font-weight: bold; } .av-main { padding: 20px; display: flex; flex-direction: column; gap: 15px; height: calc(100% - 50px); } .av-status { background: white; border: 1px solid #ccc; padding: 10px; font-weight: bold; } .av-progress-container { height: 20px; background: #ddd; border: 1px solid #aaa; position: relative; } #av-progress-bar { height: 100%; background: green; width: 0%; } .av-results { flex-grow: 1; background: white; border: 1px solid #ccc; overflow: auto; padding: 10px; font-size: 11px; font-family: monospace; }",
  "js": "var scanBtn = container.querySelector('#scan-btn'); var progress = container.querySelector('.av-progress-container'); var bar = container.querySelector('#av-progress-bar'); var results = container.querySelector('.av-results'); scanBtn.onclick = function() { scanBtn.disabled = true; progress.style.display = 'block'; results.innerHTML = 'Starting scan...<br>'; var paths = []; VFS.walk('C:', function(p) { paths.push(p); }); var i = 0; function step() { if (i < paths.length) { var p = paths[i]; bar.style.width = Math.floor((i/paths.length)*100) + '%'; if (VFS.readFile(p) && VFS.readFile(p).indexOf('MALWARE') !== -1) { results.innerHTML += '<span style=\"color:red;\">[!] Threat: ' + p + '</span><br>'; } i++; setTimeout(step, 10); } else { scanBtn.disabled = false; progress.style.display = 'none'; results.innerHTML += 'Scan complete.'; } } step(); };"
}
