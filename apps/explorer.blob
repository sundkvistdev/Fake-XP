{
  "title": "My Computer",
  "width": 700,
  "height": 500,
  "html": "<div class='explorer-container'><div class='explorer-toolbar'></div><div class='explorer-main'><div class='explorer-sidebar'></div><div class='explorer-list'></div></div></div>",
  "css": ".explorer-container { display: flex; flex-direction: column; height: 100%; background: white; font-family: Tahoma, sans-serif; } .explorer-toolbar { padding: 5px; background: #f0f0f0; border-bottom: 1px solid #ccc; display: flex; gap: 10px; align-items: center; } .explorer-main { display: flex; flex-grow: 1; overflow: hidden; } .explorer-sidebar { width: 180px; background: linear-gradient(to bottom, #748aff 0%, #4058d3 100%); color: white; padding: 10px; font-size: 11px; } .explorer-list { flex-grow: 1; overflow: auto; padding: 15px; display: flex; flex-wrap: wrap; align-content: flex-start; gap: 20px; } .sidebar-link { cursor: pointer; margin-bottom: 5px; padding: 2px 5px; } .sidebar-link:hover { text-decoration: underline; } .explorer-grid-item { width: 80px; display: flex; flex-direction: column; align-items: center; text-align: center; cursor: pointer; padding: 5px; border-radius: 3px; } .explorer-grid-item:hover { background: #e5f3ff; border: 1px solid #cce8ff; } .address-bar { flex-grow: 1; border: 1px solid #ccc; padding: 2px 5px; font-size: 11px; }",
  "js": "var currentPath = args.initialPath || 'C:'; function navigateTo(path) { currentPath = path; render(); XP_API.setWindowTitle(winId, 'My Computer - ' + path); } function render() { var toolbar = container.querySelector('.explorer-toolbar'); var sidebar = container.querySelector('.explorer-sidebar'); var list = container.querySelector('.explorer-list'); toolbar.innerHTML = ''; var backBtn = document.createElement('button'); backBtn.innerText = 'Back'; backBtn.onclick = function() { var parts = currentPath.split('/').filter(function(p) { return p.length > 0; }); if (parts.length > 1) { parts.pop(); navigateTo(parts.join('/')); } }; toolbar.appendChild(backBtn); var addr = document.createElement('input'); addr.className = 'address-bar'; addr.value = currentPath; addr.onkeydown = function(e) { if (e.key === 'Enter') navigateTo(addr.value); }; toolbar.appendChild(addr); sidebar.innerHTML = '<div style=\"font-weight:bold;margin-bottom:10px;\">File Tasks</div><div class=\"sidebar-link\" id=\"new-folder\">📁 New Folder</div><div class=\"sidebar-link\" id=\"new-file\">📄 New File</div><hr style=\"opacity:0.3;margin:10px 0;\"><div style=\"font-weight:bold;margin-bottom:10px;\">Places</div><div class=\"sidebar-link\" id=\"go-desktop\">🖥️ Desktop</div><div class=\"sidebar-link\" id=\"go-docs\">📂 Documents</div>'; sidebar.querySelector('#new-folder').onclick = function() { XP_API.showDialog({ type: 'prompt', title: 'New Folder', message: 'Name:', onOk: function(n) { if (n) { VFS.mkdir(currentPath + '/' + n); navigateTo(currentPath); } } }); }; sidebar.querySelector('#go-desktop').onclick = function() { navigateTo('C:/Desktop'); }; sidebar.querySelector('#go-docs').onclick = function() { navigateTo('C:/Documents'); }; list.innerHTML = ''; var items = VFS.ls(currentPath); items.forEach(function(item) { var p = currentPath + '/' + item; var stat = VFS.stat(p); var div = document.createElement('div'); div.className = 'explorer-grid-item'; div.innerHTML = '<img src=\"' + XP_API.getIcon(p) + '\" style=\"width:32px;height:32px;\"><span style=\"font-size:11px;margin-top:5px;\">' + item + '</span>'; div.onclick = function() { if (stat.type === 'dir') navigateTo(p); else if (stat.isLink) { try { var ld = JSON.parse(stat.content); XP_API.exec(ld.app, [ld.args]); } catch(e) { XP_API.exec(stat.content); } } else XP_API.exec('notepad', [p]); }; list.appendChild(div); }); } navigateTo(currentPath);"
}
